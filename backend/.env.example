# ── Database Configuration ──────────────────────────────────────────────────
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=YOUR_DATABASE_NAME

# ── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:8080

# ── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET_HERE

# ── Environment ────────────────────────────────────────────────────────────
NODE_ENV=development

# ── AI Provider Configuration ────────────────────────────────────────────────
# Select which AI provider to use
# Options: gemini, openrouter, groq, openai
AI_PROVIDER=openrouter

# Gemini API Key (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OpenRouter API Key (required if AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# Groq API Key (required if AI_PROVIDER=groq)
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
